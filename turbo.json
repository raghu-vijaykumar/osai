{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "depends_on": ["^build"],
      "outputs": ["dist/**"],
      "inputs": ["src/**", "tsconfig.json", "package.json"]
    },
    "test": {
      "depends_on": ["build"],
      "inputs": ["src/**", "test/**", "tsconfig.json"]
    },
    "test:integration": {
      "depends_on": ["build"],
      "cache": false
    },
    "test:coverage": {
      "depends_on": ["build"],
      "cache": false
    },
    "test:contract": {
      "cache": false
    },
    "lint": {
      "inputs": ["src/**", "test/**"]
    },
    "typecheck": {
      "depends_on": ["^build"]
    },
    "clean": {
      "cache": false
    }
  }
}
